{
	"name": "detain/myadmin-sendy-mailinglist",
	"type": "myadmin-plugin",
	"description": "Sendy mailing list integration plugin for the MyAdmin control panel. Provides automated subscriber management via the Sendy API, including account-activation hooks and event-driven mailing list subscriptions.",
	"keywords": [
		"sendy",
		"mailing-list",
		"email",
		"newsletter",
		"myadmin",
		"plugin",
		"subscriber"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=7.4",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0||^6.0||^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminSendy\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminSendy\\Tests\\": "tests/"
		}
	}
}
